{
  "manifest_version": 3,
  "name": "Nexus Universal Video Importer",
  "version": "1.0.0",
  "description": "Capture any video stream and import directly to Nexus Dashboard. Supports MP4, HLS, and more.",
  "permissions": [
    "storage",
    "activeTab",
    "webRequest",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
